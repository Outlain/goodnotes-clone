# Optional reference file if you prefer env-file based deployment.
# The default docker-compose.yml now uses inline environment variables instead.

# HTTP port exposed by the container
PORT=3000

# Inside Docker, keep this as /app/data unless you know you need a custom path.
DATA_DIR=/app/data

# Max PDF upload size in megabytes. Increase this for very large textbooks/workbooks.
PDF_UPLOAD_LIMIT_MB=512

# When true, the server tries to linearize larger uploaded PDFs with qpdf for better range loading.
PDF_LINEARIZE_UPLOADS=true

# Used to sign the login session cookie so browsers cannot forge valid sessions.
# This is not the password users type in. Use a long random string in production.
SESSION_SECRET=replace-me-with-a-long-random-secret

# Optional. Leave blank to disable the login screen completely.
# If blank, anyone who can reach the app can open it.
APP_PASSWORD=
